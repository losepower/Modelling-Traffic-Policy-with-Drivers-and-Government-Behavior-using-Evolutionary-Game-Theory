    def update_chart(self):
        if self.env_results is None:
            return
        
        self.ax.clear()
        
        if not hasattr(self, 'visible_chart_indices'):
            self.visible_chart_indices = list(range(10))
        
        actual_index = self.visible_chart_indices[self.current_chart_index]
        
        data_map = {
            0: (self.env_results.fatal, "Количество погибших"),
            1: (self.env_results.crashes, "Количество аварий"),
            2: (self.env_results.Belted_NotBelted, "Доля пристегнутых"),
            3: (self.env_results.Speedings, "Доля превышающих скорость"),
            4: (self.env_results.earns, "Доход правительства"),
            5: (self.env_results.Strict_Lite, "Доля строгих правительств"),
            6: (self.env_results.averageWaiting, "Среднее время ожидания"),
            7: (self.env_results.averageWaitingNoFat, "Среднее время ожидания без смертей"),
            8: (self.env_results.averageMaint, "Средний коэффициент обслуживания"),
            9: (self.env_results.averageSpeed, "Средняя скорость"),
        }
        
        if actual_index in data_map:
            data, title = data_map[actual_index]
            epochs = list(range(len(data)))
            
            self.ax.plot(epochs, data, linewidth=2.5, color=self.primary_color, marker='o', markersize=3, alpha=0.7)
            self.ax.set_title(title, fontsize=15, fontweight='bold', pad=15)  # 添加标题
            self.ax.set_xlabel('Эпоха', fontsize=13, fontweight='bold')
            self.ax.set_ylabel(title, fontsize=13, fontweight='bold')
            self.ax.grid(True, alpha=0.3, linestyle='--')
            self.ax.tick_params(labelsize=11)
            
            total_visible = len(self.visible_chart_indices)
            self.page_label.config(text=f"{self.current_chart_index + 1} / {total_visible}")
        
        self.canvas.draw()
    
    def prev_chart(self):
        if self.current_chart_index > 0:
            self.current_chart_index -= 1
            self.update_chart()
    
    def next_chart(self):
        if self.current_chart_index < len(self.visible_chart_indices) - 1:
            self.current_chart_index += 1
            self.update_chart()
    
    def export_chart(self):
        file_types = [
            ("PNG изображение", "*.png"),
            ("PDF документ", "*.pdf"),
            ("SVG векторная графика", "*.svg"),
        ]
        
        filename = filedialog.asksaveasfilename(
            defaultextension=".png",
            filetypes=file_types,
            title="Экспорт графика"
        )
        
        if filename:
            try:
                self.fig.savefig(filename, dpi=300, bbox_inches='tight', facecolor=self.fig.get_facecolor())
                messagebox.showinfo("Успех", f"График экспортирован в:\n{filename}")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Ошибка экспорта: {str(e)}")
    
    def export_data(self):
        file_types = [
            ("CSV файл", "*.csv"),
            ("Excel файл", "*.xlsx"),
        ]
        
        filename = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=file_types,
            title="Экспорт данных"
        )
        
        if filename:
            try:
                di = {
                    "fatal": self.env_results.fatal,
                    "crashes": self.env_results.crashes,
                    "belted": self.env_results.Belted_NotBelted,
                    "speeding": self.env_results.Speedings,
                    "earnings": self.env_results.earns,
                    "strict": self.env_results.Strict_Lite,
                    "avgWait": self.env_results.averageWaiting,
                    "avgWaitNoFatal": self.env_results.averageWaitingNoFat,
                    "avgMaint": self.env_results.averageMaint,
                    "avgSpeed": self.env_results.averageSpeed,
                }
                
                df = pd.DataFrame(di)
                
                if filename.endswith('.xlsx'):
                    df.to_excel(filename, index=False)
                else:
                    df.to_csv(filename, index=False)
                
                messagebox.showinfo("Успех", f"Данные экспортированы в:\n{filename}")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Ошибка экспорта: {str(e)}")
    
